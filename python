  <!-- SCROLL REVEAL (Intersection Observer) -->
  <script>
    (function() {
      const reveals = document.querySelectorAll('.reveal');
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('show');
          } else {
            // optional: remove class if you want hide again; but keep show to stay visible
            // entry.target.classList.remove('show'); // (commented to keep visible after reveal)
          }
        });
      }, { threshold: 0.2, rootMargin: '0px 0px -40px 0px' });

      reveals.forEach(el => observer.observe(el));

      // smooth anchor links without # jump latency
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          if (href === "#") return; // back to top handled by browser
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });
    })();
  </script>
  <!-- ensure that all reveal elements become visible eventually (if observer fails) -->
